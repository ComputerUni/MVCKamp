@model EntityLayer.Concrete.Content

@{
    ViewBag.Title = "AddContent";
    Layout = "~/Views/Shared/_WriterLayout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="font-weight-light my-1"><i class="fas fa-paper-plane mr-2"></i>Yeni İçerik</h3>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("AddContent", "WriterPanelContent", FormMethod.Post))
                    {

                        <div class="form-group">
                            <div class="input-group">
                                <input type="text" name="HeadingID" value="@ViewBag.d" />
                            </div>
                            @Html.Label("İçeriğinizi Yazınız", new { @class = "small mb-1 font-weight-bold" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                </div>
                                @Html.TextAreaFor(x => x.ContentValue, 4, 30, new { @class = "form-control" })
                            </div>
                            @Html.ValidationMessageFor(x => x.ContentValue)
                        </div>

                        <div class="form-group mt-4 mb-0">
                            <button class="btn btn-primary btn-block py-2 font-weight-bold shadow-sm">
                                <i class="fas fa-save mr-2"></i>İçeriği Kaydet
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

