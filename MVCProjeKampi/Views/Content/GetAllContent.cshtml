@using EntityLayer.Concrete
@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Content>

@{
    ViewBag.Title = "GetAllContent";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0"><i class="fas fa-search mr-2"></i> İçerik Filtreleme Paneli</h3>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("GetAllContent", "Content", FormMethod.Get))
                    {
                        <div class="input-group mb-3">
                            @Html.TextBox("p", null, new { @class = "form-control", placeholder = "Anahtar kelimeyi buraya yazın...", aria_label = "Arama" })
                            <div class="input-group-append">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fas fa-search"></i> Ara
                                </button>
                                <a href="/Content/GetAllContent" class="btn btn-outline-secondary">Temizle</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="list-group shadow-sm">
                @if (Model.Count() == 0)
                {
                    <div class="alert alert-warning text-bg-dark">Aradığınız kriterlere uygun içerik bulunamadı.</div>
                }
                else
                {
                    foreach (var irem in Model)
                    {
                        <div class="list-group-item list-group-item-action flex-column align-items-start mb-2 border-left-primary shadow-sm" style="border-left: 5px solid #007bff;">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1 text-primary">@irem.Writer.WriterName @irem.Writer.WriterSurname</h5>
                            </div>
                            <p class="mb-1 font-weight-normal text-dark" style="font-size: 1.1rem;">
                                @irem.ContentValue
                            </p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">
    @Html.PagedListPager((IPagedList)Model, page => Url.Action("GetAllContent", new { page, searchString = Request.QueryString["searchString"] }), new PagedListRenderOptions
    {
        LiElementClasses = new List<string>
        { "page-link"}
    })
</div>
