@model EntityLayer.Concrete.Category

@{
    ViewBag.Title = "AddCategory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="sweetalert2.min.js"></script>
<link rel="stylesheet" href="sweetalert2.min.css">
<script src="sweetalert2.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Kategori Ekleme Sayfası</h1>
            </div>
        </div>
    </div>
</section>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="font-weight-light my-1"><i class="fas fa-clipboard-list mr-3"></i>Yeni Kategori</h3>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("AddCategory", "AdminCategory", FormMethod.Post))
                    {

                        <div class="form-group">
                            @Html.Label("Kategori Adı", new { @class = "small mb-1 font-weight-bold" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fas fa-sticky-note"></i></span>
                                </div>
                                @Html.TextBoxFor(x => x.CategoryName, new { @class = "form-control" })
                            </div>
                            @Html.ValidationMessageFor(x => x.CategoryName)
                        </div>

                        <div class="form-group">
                            @Html.Label("Açıklama", new { @class = "small mb-1 font-weight-bold" })
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fas fa-blog"></i></span>
                                </div>
                                @Html.TextBoxFor(x => x.CategoryDescription, new { @class = "form-control" })
                            </div>
                            @Html.ValidationMessageFor(x => x.CategoryDescription)
                        </div>

                        <div class="form-group mt-4 mb-0">
                            <button class="btn btn-primary btn-block py-2 font-weight-bold shadow-sm" id="btn1">
                                <i class="fas fa-save mr-2"></i>Kategoriyi Sisteme Kaydet
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $('#btn1').click(function (e) {
        e.preventDefault();
        var form = $(this).closest('form');

        Swal.fire({
            title: "Emin misiniz?",
            text: "Kategori sisteme kaydedilecek.",
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Evet, Kaydet",
            cancelButtonText: "Vazgeç",
            draggable: true
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    })
</script>