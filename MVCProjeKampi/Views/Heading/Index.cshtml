@{ string color = "";}


<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
    <!-- Content Header (Page header) -->
    <!-- Main content -->
    <section class="content">

        <!-- Default box -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Başlık İşlemleri</h3>

                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse" data-toggle="tooltip" title="Collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                    <button type="button" class="btn btn-tool" data-card-widget="remove" data-toggle="tooltip" title="Remove">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped projects">
                    <thead>
                        <tr>
                            <th style="width: 1%">
                                #
                            </th>
                            <th style="width: 20%">
                                Başlık Adı
                            </th>
                            <th style="width: 30%">
                                Oluşturan Yazar
                            </th>
                            <th style="width: 8%" class="text-center">
                                Kategori
                            </th>
                            <th style="width: 20%">
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var irem in Model)
                        {
                            if (@irem.Category.CategoryName == "Tiyatro")
                            {
                                color = "badge badge-warning";
                            }
                            if (irem.Category.CategoryName == "Spor")
                            {
                                color = "badge badge-success";
                            }
                            if (irem.Category.CategoryName == "Kitap")
                            {
                                color = "badge badge-danger";
                            }
                            if (irem.Category.CategoryName == "Eğitim")
                            {
                                color = "badge badge-secondary";
                            }
                            if (irem.Category.CategoryName == "Film")
                            {
                                color = "badge badge-info";
                            }
                            if (irem.Category.CategoryName == "Dizi")
                            {
                                color = "badge badge-primary";
                            }
                            if (irem.Category.CategoryName == "Sosyal")
                            {
                                color = "badge badge-danger";
                            }
                            <tr>
                                <td>
                                    #@irem.HeadingID
                                </td>
                                <td>
                                    <a>
                                        @irem.HeadingName
                                    </a>
                                    <br />
                                    <small>
                                        @(((DateTime)irem.HeadingTime).ToString("dd-MMM-yyyy"))
                                    </small>
                                </td>
                                <td>
                                    <ul class="list-inline">
                                        <li class="list-inline-item">
                                            <img style="text-align:center;" alt="Avatar" class="table-avatar" src="@irem.Writer.WriterImage">
                                        </li>
                                    </ul>
                                </td>
                                <td class="project-state">
                                    <span class="@color">@irem.Category.CategoryName</span>
                                </td>
                                <td class="project-actions text-right">
                                    <a class="btn btn-primary btn-sm" href="/Content/ContentByHeading/@irem.HeadingID">
                                        <i class="fas fa-folder">
                                        </i>
                                        Yazılar
                                    </a>
                                    <a class="btn btn-info btn-sm" href="/Heading/EditHeading/@irem.HeadingID">
                                        <i class="fas fa-pencil-alt">
                                        </i>
                                        Düzenle
                                    </a>
                                    <a class="btn btn-danger btn-sm" href="#">
                                        <i class="fas fa-trash">
                                        </i>
                                        Sil
                                    </a>
                                </td>
                            </tr>

                        }
                    </tbody>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </section>
</body>
</html>
<a href="/Heading/AddHeading/" class="btn btn-outline-secondary">Yeni Başlık</a>
