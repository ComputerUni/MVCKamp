<div class="container mt-4">
    <button class="btn btn-outline-success" data-toggle="modal" data-target="#Modal1">
        Yeni Hakkımızda Yazı Girişi
    </button>
</div>


<div class="modal" id="Modal1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Hakkımızda Metin Girişi</h2>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="container mt-4">
                @using (Html.BeginForm("AddAbout", "About", FormMethod.Post))
                {
                    <div class="modal-body">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Hakkımda Metin 1</label>
                            <input type="text" name="AboutDetails1" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Hakkımda Metin 2</label>
                            <input type="text" name="AboutDetails2" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Hakkımda Görsel 1</label>
                            <input type="text" name="AboutImage1" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Hakkımda Görsel 2</label>
                            <input type="text" name="AboutImage2" class="form-control" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-primary">Kaydet</button>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Kapat</button>
                    </div>
                }

            </div>
        </div>
    </div>
</div>